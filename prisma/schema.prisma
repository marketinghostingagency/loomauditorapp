datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Audit {
  id                String   @id @default(cuid())
  createdAt         DateTime @default(now())
  url               String
  brandName         String
  apexDomain        String?
  metaPixelFound    Boolean  @default(false)
  script            String?
  sitemapXml        String?
  affiliatePrograms String?  // JSON stringified array representing found programs
  landingPageUrl    String?
  socialLinks       String?  // JSON stringified array of social profiles
  aiAnalysis        String?
  sentAt            DateTime?
  sentTheme         String?
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  brandName String?
  auditId   String?
  createdAt DateTime @default(now())
}

model StyleRule {
  id        String   @id @default(cuid())
  section   String
  rule      String
  createdAt DateTime @default(now())
}

model BrandBook {
  id            String   @id @default(cuid())
  brandName     String   @unique
  primaryColor  String?
  secondaryColor String?
  accentColor   String?
  typography    String?
  logoUrl       String?
  toneOfVoice   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  assets        CreativeAsset[]
}

model CreativeAsset {
  id            String   @id @default(cuid())
  brandId       String
  brand         BrandBook @relation(fields: [brandId], references: [id], onDelete: Cascade)
  title         String
  type          String   // e.g. 'image', 'video', 'template'
  platform      String?  // e.g. 'instagram', 'tiktok', 'facebook'
  dimensions    String?  // e.g. '1080x1920'
  fileUrl       String
  tags          String?  // JSON stringified array
  status        String   @default("ACTIVE") // 'ACTIVE' or 'ARCHIVED'
  createdAt     DateTime @default(now())
}
