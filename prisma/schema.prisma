datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Audit {
  id                String   @id @default(cuid())
  createdAt         DateTime @default(now())
  url               String
  brandName         String
  apexDomain        String?
  metaPixelFound    Boolean  @default(false)
  script            String?
  sitemapXml        String?
  affiliatePrograms String?  // JSON stringified array representing found programs
  landingPageUrl    String?
  socialLinks       String?  // JSON stringified array of social profiles
  aiAnalysis        String?
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  brandName String?
  auditId   String?
  createdAt DateTime @default(now())
}

model StyleRule {
  id        String   @id @default(cuid())
  section   String
  rule      String
  createdAt DateTime @default(now())
}

